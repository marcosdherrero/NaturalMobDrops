	"authors": [
		"Berkle"
	],
	"license": "CC0-1.0",
	"icon": "assets/naturalmobdrops/icon.png",
	"environment": "*",
	"accessWidener": "naturalmobdrops.accesswidener",
	"mixins": [
		"naturalmobdrops.mixins.json"
	],
	"entrypoints": {
		"main": [
			"net.berkle.naturalmobdrops.NaturalMobDropsMain"
		],
		"client": [
			"net.berkle.naturalmobdrops.client.NaturalMobDropsClient"
		]
	},
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
